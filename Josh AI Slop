@bot.command()
async def sheet(ctx, url: str = None):
    """Opens a provided Google Sheet URL and prints a rough table."""
    # Check if a URL was provided as an argument
    if url is None:
        await ctx.send("a google sheets URL is needed")
        return

    try:
        # Attempt to open the spreadsheet provided in the command
        target_sh = gc.open_by_url(url)
        target_wks = target_sh.get_worksheet(0)
        data = target_wks.get_all_values()
        
        if not data:
            await ctx.send("The spreadsheet is empty.")
            return

        # Format the data into a rough text table
        table_lines = []
        for row in data:
            line = " | ".join(str(cell) for cell in row)
            table_lines.append(line)
            if len(table_lines) == 1:
                table_lines.append("-" * len(line))

        final_table = "\n".join(table_lines)
        
        if len(final_table) > 1900:
            await ctx.send("The sheet is too large to display in a single message!")
        else:
            await ctx.send(f"```\n{final_table}\n```")
            
    except gspread.exceptions.SpreadsheetNotFound:
        # Error triggered if the bot lacks permission 
        await ctx.send("share the sheet with the bot")
    except Exception as e:
        await ctx.send(f"Error opening sheet: Please check the sheet is shared with {"read-write@enigmafia-discord-integration.iam.gserviceaccount.com"}.")

@bot.command()
async def schedule_dm(ctx, date_input: str, time_input: str, user_id: int, *, message: str):
    """
    Schedules a DM for a specific user.
    Usage:!schedule_dm 3/29/26 11:45pm 1234567890 Hello!
    """
    try:
        # 1. Parse the interpreted date and time
        full_input = f"{date_input} {time_input}"
        scheduled_time = parser.parse(full_input, fuzzy=True)
        now = datetime.now()

        # 2. Check if the time is in the future
        if scheduled_time <= now:
            await ctx.send("❌ Error: That time is in the past. Please provide a future date/time.")
            return

        # 3. Confirm with the user
        formatted_time = scheduled_time.strftime('%A, %B %d, %Y at %I:%M %p')
        await ctx.send(f"I've interpreted the time as: **{formatted_time}**\nIs this correct? (Type **yes** to confirm)")

        def check(m):
            return m.author == ctx.author and m.channel == ctx.channel and m.content.lower() == 'yes'

        try:
            # Wait 30 seconds for a "yes" response
            await bot.wait_for('message', check=check, timeout=30.0)
        except asyncio.TimeoutError:
            await ctx.send("⏳ Confirmation timed out. Scheduling cancelled.")
            return

        # 4. Schedule the task
        delay = (scheduled_time - now).total_seconds()
        await ctx.send(f"✅ Confirmed! Message scheduled for {formatted_time}.")
        
        # This runs in the background without blocking other bot commands
        await asyncio.sleep(delay)

        # 5. Send the message
        try:
            user = await bot.fetch_user(user_id)
            await user.send(message)
            print(f"Sent scheduled message to {user.name}")
        except discord.Forbidden:
            print(f"Could not DM user {user_id} (DMs closed or no shared server)")
        except Exception as e:
            print(f"Error sending scheduled DM: {e}")

    except ValueError:
        await ctx.send("❌ Error: I couldn't understand that date/time format. Use 'MM/DD/YY HH:MMam/pm'.")
    except Exception as e:
        await ctx.send(f"❌ An unexpected error occurred: {e}")

