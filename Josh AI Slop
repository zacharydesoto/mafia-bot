@bot.command()
async def sheet(ctx, url: str = None):
    """Opens a provided Google Sheet URL and prints a rough table."""
    # Check if a URL was provided as an argument
    if url is None:
        await ctx.send("a google sheets URL is needed")
        return

    try:
        # Attempt to open the spreadsheet provided in the command
        target_sh = gc.open_by_url(url)
        target_wks = target_sh.get_worksheet(0)
        data = target_wks.get_all_values()
        
        if not data:
            await ctx.send("The spreadsheet is empty.")
            return

        # Format the data into a rough text table
        table_lines = []
        for row in data:
            line = " | ".join(str(cell) for cell in row)
            table_lines.append(line)
            if len(table_lines) == 1:
                table_lines.append("-" * len(line))

        final_table = "\n".join(table_lines)
        
        if len(final_table) > 1900:
            await ctx.send("The sheet is too large to display in a single message!")
        else:
            await ctx.send(f"```\n{final_table}\n```")
            
    except gspread.exceptions.SpreadsheetNotFound:
        # Error triggered if the bot lacks permission 
        await ctx.send("share the sheet with the bot")
    except Exception as e:
        await ctx.send(f"Error opening sheet: Please check the sheet is shared with {"read-write@enigmafia-discord-integration.iam.gserviceaccount.com"}.")

active_tasks = {}

async def run_scheduled_dm(user_id, wait_seconds, scheduled_time_str, message):
    """Internal function to handle the timer and sending."""
    try:
        await asyncio.sleep(wait_seconds)
        user = await bot.fetch_user(user_id)
        await user.send(message)
        print(f"Delivered scheduled message to {user_id}")
    except asyncio.CancelledError:
        # This is triggered when we call task.cancel()
        print(f"Task for {user_id} was cancelled.")
        raise 
    except Exception as e:
        print(f"Error sending to {user_id}: {e}")
    finally:
        # Clean up the tracker after the task finishes or is cancelled
        if user_id in active_tasks:
            active_tasks[user_id] = [t for t in active_tasks[user_id] if t[1] != scheduled_time_str]
            if not active_tasks[user_id]:
                del active_tasks[user_id]

@bot.command()
async def schedule_dm(ctx, date_input: str, time_input: str, user_id: int, *, message: str):
    """Schedules a DM and adds it to the tracker."""
    try:
        full_input = f"{date_input} {time_input}"
        scheduled_time = parser.parse(full_input, fuzzy=True)
        wait_seconds = (scheduled_time - datetime.now()).total_seconds()

        if wait_seconds <= 0:
            await ctx.send("❌ Error: Time is in the past.")
            return

        # Confirmation
        formatted_time = scheduled_time.strftime('%Y-%m-%d %I:%M %p')
        await ctx.send(f"Schedule for {formatted_time}? (Type **yes**)")
        
        def check(m): return m.author == ctx.author and m.content.lower() == 'yes'
        await bot.wait_for('message', check=check, timeout=30.0)

        # Create the task and store it
        task = asyncio.create_task(run_scheduled_dm(user_id, wait_seconds, formatted_time, message))
        
        if user_id not in active_tasks:
            active_tasks[user_id] = []
        
        active_tasks[user_id].append((task, formatted_time, message[:20] + "..."))
        
        await ctx.send(f"✅ Message scheduled for User {user_id} at {formatted_time}.")

    except Exception as e:
        await ctx.send(f"❌ Error: {e}")

# --- NEW COMMAND: LIST SCHEDULED ---
@bot.command()
async def list_scheduled(ctx):
    """Shows all currently pending scheduled messages."""
    if not active_tasks:
        await ctx.send("📅 No messages are currently scheduled.")
        return

    report = "📋 **Pending Scheduled Messages:**\n"
    for uid, tasks in active_tasks.items():
        for _, time_str, msg_preview in tasks:
            report += f"• **User <@{uid}> or {uid}**: {time_str} | \"{msg_preview}\"\n"

    # Discord limit is 2000 chars
    if len(report) > 2000:
        await ctx.send("The list is too long to display.")
    else:
        await ctx.send(report)

# --- NEW COMMAND: CANCEL SCHEDULED ---
@bot.command()
async def cancel_scheduled(ctx, user_id: int):
    """Cancels ALL pending messages for a specific Discord ID."""
    if user_id not in active_tasks:
        await ctx.send(f"❌ No scheduled messages found for User {user_id}.")
        return

    task_list = active_tasks[user_id]
    count = len(task_list)

    for task, _, _ in task_list:
        task.cancel() # Stops the asyncio timer immediately

    # Clean up entry
    del active_tasks[user_id]
    await ctx.send(f"🛑 Successfully cancelled **{count}** scheduled message(s) for User {user_id}.")

@bot.command()
async def night_message(ctx, url: str, date_input: str, time_input: str):
    """
    Schedules individual DMs from a Google Sheet.
    Includes immediate error reporting and integration with!list_scheduled.
    """
    try:
        # 1. Parse and validate the date/time
        full_input = f"{date_input} {time_input}"
        scheduled_time = parser.parse(full_input, fuzzy=True)
        wait_seconds = (scheduled_time - datetime.now()).total_seconds()

        if wait_seconds <= 0:
            await ctx.send("❌ Error: That time is in the past. Please provide a future date/time.")
            return

        # 2. Confirmation step
        formatted_time = scheduled_time.strftime('%A, %B %d, %Y at %I:%M %p')
        await ctx.send(f"I've interpreted the blast time as: **{formatted_time}**\nIs this correct? (Type **yes** to confirm)")

        def check(m):
            return m.author == ctx.author and m.channel == ctx.channel and m.content.lower() == 'yes'

        try:
            await bot.wait_for('message', check=check, timeout=30.0)
        except asyncio.TimeoutError:
            await ctx.send("⏳ Confirmation timed out. Scheduling cancelled.")
            return

        # 3. Read the sheet immediately to report errors
        try:
            sh = gc.open_by_url(url)
            worksheet = sh.get_worksheet(0)
            data = worksheet.get_all_values()
            
            rows_to_process = data[1:] if len(data) > 1 else ""
            if not rows_to_process:
                await ctx.send("❌ The spreadsheet is empty (no data found after the header).")
                return

            scheduled_count = 0
            immediate_failures = []

            for row in rows_to_process:
                if len(row) >= 3:
                    user_id_str = row[1].strip()
                    message_content = row[2]

                    if user_id_str.isdigit():
                        uid = int(user_id_str)
                        
                        # Create background task
                        task = asyncio.create_task(
                            run_scheduled_dm(uid, wait_seconds, formatted_time, message_content)
                        )
                        
                        # Track in global list
                        if uid not in active_tasks:
                            active_tasks[uid] = []
                        active_tasks[uid].append((task, formatted_time, message_content[:20] + "..."))
                        scheduled_count += 1
                    else:
                        immediate_failures.append(f"Row {rows_to_process.index(row)+2}: '{user_id_str}' is not a valid ID.")
                else:
                    immediate_failures.append(f"Row {rows_to_process.index(row)+2}: Missing columns.")

            # 4. Final Scheduling Report
            report = f"📊 **Night Blast Scheduled**\n✅ Queued: {scheduled_count}\n❌ Immediate Failures: {len(immediate_failures)}"
            
            if immediate_failures:
                report += "\n\n**Formatting Errors (Not Scheduled):**\n" + "\n".join(immediate_failures[:10])
                if len(immediate_failures) > 10:
                    report += f"\n*(and {len(immediate_failures) - 10} more...)*"

            if len(report) > 2000:
                await ctx.author.send(f"Scheduled {scheduled_count} messages. {len(immediate_failures)} format errors encountered.")
            else:
                await ctx.author.send(report)

        except gspread.exceptions.SpreadsheetNotFound:
            await ctx.send("❌ Error: I cannot access that sheet. Share the sheet with the bot!")
            
    except ValueError:
        await ctx.send("❌ Error: I couldn't understand that date/time format. Use 'MM/DD/YY HH:MMam/pm'.")
    except Exception as e:
        await ctx.send(f"❌ An unexpected error occurred: {e}")

bot.run(TOKEN)
