@bot.command()
async def night_message(ctx, url: str, date_input: str, time_input: str):
    """
    Schedules a mass message blast from a Google Sheet and reports specific errors.
    Usage:!night_message https://sheet-url 3/29/26 11:59pm
    """
    try:
        # 1. Parse and validate the date/time
        full_input = f"{date_input} {time_input}"
        scheduled_time = parser.parse(full_input, fuzzy=True)
        now = datetime.now()

        if scheduled_time <= now:
            await ctx.send("❌ Error: That time is in the past. Please provide a future date/time.")
            return

        # 2. Confirmation step
        formatted_time = scheduled_time.strftime('%A, %B %d, %Y at %I:%M %p')
        await ctx.send(f"I've interpreted the blast time as: **{formatted_time}**\nIs this correct? (Type **yes** to confirm)")

        def check(m):
            return m.author == ctx.author and m.channel == ctx.channel and m.content.lower() == 'yes'

        try:
            await bot.wait_for('message', check=check, timeout=30.0)
        except asyncio.TimeoutError:
            await ctx.send("⏳ Confirmation timed out. Scheduling cancelled.")
            return

        # 3. Schedule the background task
        delay = (scheduled_time - now).total_seconds()
        await ctx.send(f"✅ Confirmed! Reading sheet and scheduling send for {formatted_time}...")
        
        await asyncio.sleep(delay)

        # 4. Open the sheet and send messages
        try:
            sh = gc.open_by_url(url)
            worksheet = sh.get_worksheet(0)
            data = worksheet.get_all_values() 
            
            rows_to_process = data[1:] if len(data) > 1 else ""
            
            sent_count = 0
            failures = []# To store specific reasons for each failure

            for row in rows_to_process:
                if len(row) >= 3:
                    user_id_str = row[1].strip()
                    message_content = row[2]

                    if user_id_str.isdigit():
                        uid = int(user_id_str)
                        try:
                            user = await bot.fetch_user(uid)
                            await user.send(message_content)
                            sent_count += 1
                        except discord.Forbidden:
                            # Triggered if DMs are closed or no mutual server
                            failures.append(f"ID {uid}: DMs closed or no shared server.")
                        except discord.NotFound:
                            failures.append(f"ID {uid}: User not found (invalid ID).")
                        except discord.HTTPException as e:
                            failures.append(f"ID {uid}: API Error (Code {e.code}).")
                        except Exception as e:
                            failures.append(f"ID {uid}: Unexpected error: {e}")
                    else:
                        failures.append(f"Invalid format: '{user_id_str}' is not a numeric ID.")
            
            # 5. Send report to the user
            report = f"📊 **Night Blast Complete**\n✅ Sent: {sent_count}\n❌ Failed: {len(failures)}"
            
            if failures:
                report += "\n\n**Failure Details:**\n" + "\n".join(failures[:15]) # Limit list length
                if len(failures) > 15:
                    report += f"\n*(and {len(failures) - 15} more failures...)*"

            # Check for Discord's 2000 character message limit [3]
            if len(report) > 2000:
                await ctx.author.send(f"Night blast complete: {sent_count} sent, {len(failures)} failed. (Report too long for Discord).")
            else:
                await ctx.author.send(report)

        except gspread.exceptions.SpreadsheetNotFound:
            await ctx.author.send("❌ Error: Scheduled blast failed because I lost access to the sheet.")
        except Exception as e:
            print(f"Error during scheduled night blast: {e}")

    except ValueError:
        await ctx.send("❌ Error: I couldn't understand that date/time. Use 'MM/DD/YY HH:MMam/pm'.")
    except Exception as e:
        await ctx.send(f"❌ An unexpected error occurred: {e}")

