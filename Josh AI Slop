@bot.command()
async def dm(ctx, user_id: int, *, message: str):
    """
    Sends a DM to a user by ID.
    Usage:!dm 123456789012345678 Your message here
    """
    try:
        # fetch_user queries the API directly for the user object
        user = await bot.fetch_user(user_id)
        
        # Attempt to send the message
        await user.send(message)
        await ctx.send(f"✅ Successfully sent message to **{user.name}**")
        
    except discord.Forbidden:
        # Error code 50007: Cannot send messages to this user
        await ctx.send("❌ Error: Cannot DM this user. They may have DMs disabled, or the bot and user share no mutual servers.")
    
    except discord.NotFound:
        await ctx.send("❌ Error: No user was found with that ID.")
        
    except Exception as e:
        await ctx.send(f"❌ An unexpected error occurred: {e}")

